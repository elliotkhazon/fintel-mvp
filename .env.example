GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# SurrealDB — runs in k3s (Docker Desktop) exposed via NodePort 30800
# SURREAL_URL takes priority; if omitted, derived from SURREAL_HTTP_ENDPOINT automatically
SURREAL_HTTP_ENDPOINT=http://localhost:30800
SURREAL_URL=ws://localhost:30800/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=fintel
SURREAL_DB=earnings_model
